<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- MainWindow -->
    <sys:String x:Key="S.AppTitle">Dekapu Launcher</sys:String>
    <sys:String x:Key="S.BtnRefresh">Refresh</sys:String>
    <sys:String x:Key="S.BtnLaunch">Launch</sys:String>
    <sys:String x:Key="S.BtnSettings">Settings</sys:String>
    <sys:String x:Key="S.GrpOsc">OSC Lock</sys:String>
    <sys:String x:Key="S.BtnLock">Lock</sys:String>
    <sys:String x:Key="S.BtnRelease">Release</sys:String>
    <sys:String x:Key="S.ColName">Name</sys:String>
    <sys:String x:Key="S.ColUsers">Users</sys:String>
    <sys:String x:Key="S.UpdatedAt">Updated: {0}</sys:String>
    <sys:String x:Key="S.None">(None)</sys:String>

    <!-- SettingsWindow -->
    <sys:String x:Key="S.WndSettings">Settings</sys:String>
    <sys:String x:Key="S.LblProfile">Profile:</sys:String>
    <sys:String x:Key="S.LblExtraArgs">Launch Args:</sys:String>
    <sys:String x:Key="S.LblOscPort">OSC Port:</sys:String>
    <sys:String x:Key="S.LblOscAddress">OSC Address:</sys:String>
    <sys:String x:Key="S.LblApiUrl">API URL:</sys:String>
    <sys:String x:Key="S.LblLauncher">Launcher:</sys:String>
    <sys:String x:Key="S.LblVr">VR:</sys:String>
    <sys:String x:Key="S.ChkVr">Launch in VR mode</sys:String>
    <sys:String x:Key="S.LblVrcCheck">Duplicate Launch:</sys:String>
    <sys:String x:Key="S.ChkVrcCheck">Block launch if VRChat is already running</sys:String>
    <sys:String x:Key="S.LblTheme">Theme:</sys:String>
    <sys:String x:Key="S.ThemeLight">Light</sys:String>
    <sys:String x:Key="S.ThemeDark">Dark</sys:String>
    <sys:String x:Key="S.ThemeSystem">System</sys:String>
    <sys:String x:Key="S.LblLang">Language:</sys:String>
    <sys:String x:Key="S.BtnBrowse">Browse...</sys:String>
    <sys:String x:Key="S.DlgBrowseTitle">Select VRChat Launcher</sys:String>
    <sys:String x:Key="S.DlgBrowseFilter">Executable (*.exe)|*.exe</sys:String>
    <sys:String x:Key="S.BtnOk">OK</sys:String>
    <sys:String x:Key="S.BtnCancel">Cancel</sys:String>

    <!-- Errors / Dialogs (code-behind) -->
    <sys:String x:Key="S.ErrInput">Input Error</sys:String>
    <sys:String x:Key="S.ErrProfileMsg">Profile must be an integer from 0 to 99</sys:String>
    <sys:String x:Key="S.ErrPortMsg">Port must be an integer from 1 to 65535</sys:String>
    <sys:String x:Key="S.ErrOscAddressMsg">OSC address must start with /</sys:String>
    <sys:String x:Key="S.ErrOscTitle">OSC Error</sys:String>
    <sys:String x:Key="S.ErrTitle">Error</sys:String>
    <sys:String x:Key="S.DlgConfirmTitle">Confirm</sys:String>
    <sys:String x:Key="S.DlgLaunchMsg" xml:space="preserve">Launch this instance?&#x0a;&#x0a;Name: {0}</sys:String>
    <sys:String x:Key="S.ErrNoLauncher" xml:space="preserve">VRChat launcher not found:&#x0a;{0}</sys:String>
<sys:String x:Key="S.VrcRunningMsg">VRChat is already running. Please close it before launching.</sys:String>

</ResourceDictionary>
