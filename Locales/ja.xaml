<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- MainWindow -->
    <sys:String x:Key="S.AppTitle">でかプランチャー</sys:String>
    <sys:String x:Key="S.BtnRefresh">更新</sys:String>
    <sys:String x:Key="S.BtnLaunch">起動</sys:String>
    <sys:String x:Key="S.BtnSettings">設定</sys:String>
    <sys:String x:Key="S.GrpOsc">OSCロック</sys:String>
    <sys:String x:Key="S.BtnLock">ロック</sys:String>
    <sys:String x:Key="S.BtnRelease">開放</sys:String>
    <sys:String x:Key="S.ColName">名前</sys:String>
    <sys:String x:Key="S.ColUsers">人数</sys:String>
    <sys:String x:Key="S.UpdatedAt">更新日時：{0}</sys:String>
    <sys:String x:Key="S.None">（なし）</sys:String>

    <!-- SettingsWindow -->
    <sys:String x:Key="S.WndSettings">設定</sys:String>
    <sys:String x:Key="S.LblProfile">プロファイル:</sys:String>
    <sys:String x:Key="S.LblExtraArgs">起動オプション:</sys:String>
    <sys:String x:Key="S.LblOscPort">OSCポート:</sys:String>
    <sys:String x:Key="S.LblOscAddress">OSCアドレス:</sys:String>
    <sys:String x:Key="S.LblApiUrl">API URL:</sys:String>
    <sys:String x:Key="S.LblLauncher">ランチャー:</sys:String>
    <sys:String x:Key="S.LblVr">VR:</sys:String>
    <sys:String x:Key="S.ChkVr">VRモードで起動する</sys:String>
    <sys:String x:Key="S.LblVrcCheck">多重起動防止:</sys:String>
    <sys:String x:Key="S.ChkVrcCheck">VRChatが起動中なら起動しない</sys:String>
    <sys:String x:Key="S.LblTheme">テーマ:</sys:String>
    <sys:String x:Key="S.ThemeLight">ライト</sys:String>
    <sys:String x:Key="S.ThemeDark">ダーク</sys:String>
    <sys:String x:Key="S.ThemeSystem">システム</sys:String>
    <sys:String x:Key="S.LblLang">言語:</sys:String>
    <sys:String x:Key="S.BtnBrowse">参照...</sys:String>
    <sys:String x:Key="S.DlgBrowseTitle">VRChatランチャーを選択</sys:String>
    <sys:String x:Key="S.DlgBrowseFilter">実行ファイル (*.exe)|*.exe</sys:String>
    <sys:String x:Key="S.BtnOk">OK</sys:String>
    <sys:String x:Key="S.BtnCancel">キャンセル</sys:String>

    <!-- Errors / Dialogs (code-behind) -->
    <sys:String x:Key="S.ErrInput">入力エラー</sys:String>
    <sys:String x:Key="S.ErrProfileMsg">プロファイルは0〜99の整数で入力してください</sys:String>
    <sys:String x:Key="S.ErrPortMsg">ポート番号は1〜65535の整数で入力してください</sys:String>
    <sys:String x:Key="S.ErrOscAddressMsg">OSCアドレスは / で始まる文字列を入力してください</sys:String>
    <sys:String x:Key="S.ErrOscTitle">OSCエラー</sys:String>
    <sys:String x:Key="S.ErrTitle">エラー</sys:String>
    <sys:String x:Key="S.DlgConfirmTitle">確認</sys:String>
    <sys:String x:Key="S.DlgLaunchMsg" xml:space="preserve">以下のインスタンスで起動しますか？&#x0a;&#x0a;名前: {0}</sys:String>
    <sys:String x:Key="S.ErrNoLauncher" xml:space="preserve">ランチャーが見つかりません:&#x0a;{0}</sys:String>
<sys:String x:Key="S.VrcRunningMsg">VRChatが起動中のため起動できません。先にVRChatを終了してください。</sys:String>

</ResourceDictionary>
