<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- MainWindow -->
    <sys:String x:Key="S.AppTitle">BuppaRengou 런처</sys:String>
    <sys:String x:Key="S.BtnRefresh">새로고침</sys:String>
    <sys:String x:Key="S.BtnLaunch">실행</sys:String>
    <sys:String x:Key="S.BtnSettings">설정</sys:String>
    <sys:String x:Key="S.GrpOsc">OSC 잠금</sys:String>
    <sys:String x:Key="S.BtnLock">잠금</sys:String>
    <sys:String x:Key="S.BtnRelease">해제</sys:String>
    <sys:String x:Key="S.ColName">이름</sys:String>
    <sys:String x:Key="S.ColUsers">인원</sys:String>
    <sys:String x:Key="S.UpdatedAt">업데이트: {0}</sys:String>
    <sys:String x:Key="S.None">（없음）</sys:String>

    <!-- SettingsWindow -->
    <sys:String x:Key="S.WndSettings">설정</sys:String>
    <sys:String x:Key="S.LblProfile">프로필:</sys:String>
    <sys:String x:Key="S.LblExtraArgs">실행 옵션:</sys:String>
    <sys:String x:Key="S.LblOscPort">OSC 포트:</sys:String>
    <sys:String x:Key="S.LblOscAddress">OSC 주소:</sys:String>
    <sys:String x:Key="S.LblApiUrl">API URL:</sys:String>
    <sys:String x:Key="S.LblLauncher">런처:</sys:String>
    <sys:String x:Key="S.LblVr">VR:</sys:String>
    <sys:String x:Key="S.ChkVr">VR 모드로 실행</sys:String>
    <sys:String x:Key="S.LblVrcCheck">중복 실행 방지:</sys:String>
    <sys:String x:Key="S.ChkVrcCheck">VRChat이 실행 중이면 실행하지 않음</sys:String>
    <sys:String x:Key="S.LblTheme">테마:</sys:String>
    <sys:String x:Key="S.ThemeLight">라이트</sys:String>
    <sys:String x:Key="S.ThemeDark">다크</sys:String>
    <sys:String x:Key="S.ThemeSystem">시스템</sys:String>
    <sys:String x:Key="S.LblLang">언어:</sys:String>
    <sys:String x:Key="S.BtnBrowse">찾아보기...</sys:String>
    <sys:String x:Key="S.DlgBrowseTitle">VRChat 런처 선택</sys:String>
    <sys:String x:Key="S.DlgBrowseFilter">실행 파일 (*.exe)|*.exe</sys:String>
    <sys:String x:Key="S.BtnOk">확인</sys:String>
    <sys:String x:Key="S.BtnCancel">취소</sys:String>

    <!-- Errors / Dialogs (code-behind) -->
    <sys:String x:Key="S.ErrInput">입력 오류</sys:String>
    <sys:String x:Key="S.ErrProfileMsg">프로필은 0에서 99 사이의 정수로 입력해 주세요</sys:String>
    <sys:String x:Key="S.ErrPortMsg">포트 번호는 1에서 65535 사이의 정수로 입력해 주세요</sys:String>
    <sys:String x:Key="S.ErrOscAddressMsg">OSC 주소는 / 로 시작해야 합니다</sys:String>
    <sys:String x:Key="S.ErrOscTitle">OSC 오류</sys:String>
    <sys:String x:Key="S.ErrTitle">오류</sys:String>
    <sys:String x:Key="S.DlgConfirmTitle">확인</sys:String>
    <sys:String x:Key="S.DlgLaunchMsg" xml:space="preserve">다음 인스턴스로 실행하시겠습니까?&#x0a;&#x0a;이름: {0}</sys:String>
    <sys:String x:Key="S.ErrNoLauncher" xml:space="preserve">런처를 찾을 수 없습니다:&#x0a;{0}</sys:String>
<sys:String x:Key="S.VrcRunningMsg">VRChat이 이미 실행 중입니다. 먼저 VRChat을 종료해 주세요.</sys:String>

</ResourceDictionary>
