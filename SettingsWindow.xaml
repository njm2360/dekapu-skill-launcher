<Window x:Class="DekapuSkillLauncher.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.WndSettings}"
        Width="440" Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="Yu Gothic UI"
        FontSize="13"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource WindowFg}">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- プロファイル -->
        <Label Grid.Row="0" Grid.Column="0" Content="{DynamicResource S.LblProfile}" VerticalAlignment="Center" Margin="0,4,8,4"/>
        <TextBox x:Name="_profileBox" Grid.Row="0" Grid.Column="1" Width="60" HorizontalAlignment="Left" Margin="0,4,0,4" VerticalContentAlignment="Center"/>

        <!-- 起動オプション -->
        <Label Grid.Row="1" Grid.Column="0" Content="{DynamicResource S.LblExtraArgs}" VerticalAlignment="Center" Margin="0,4,8,4"/>
        <TextBox x:Name="_extraArgsBox" Grid.Row="1" Grid.Column="1" Margin="0,4,0,4" VerticalContentAlignment="Center"/>

        <!-- OSCポート -->
        <Label Grid.Row="2" Grid.Column="0" Content="{DynamicResource S.LblOscPort}" VerticalAlignment="Center" Margin="0,4,8,4"/>
        <TextBox x:Name="_oscPortBox" Grid.Row="2" Grid.Column="1" Width="80" HorizontalAlignment="Left" Margin="0,4,0,4" VerticalContentAlignment="Center"/>

        <!-- OSCアドレス -->
        <Label Grid.Row="3" Grid.Column="0" Content="{DynamicResource S.LblOscAddress}" VerticalAlignment="Center" Margin="0,4,8,4"/>
        <TextBox x:Name="_oscAddressBox" Grid.Row="3" Grid.Column="1" Margin="0,4,0,4" VerticalContentAlignment="Center"/>

        <!-- ランチャーパス -->
        <Label Grid.Row="4" Grid.Column="0" Content="{DynamicResource S.LblLauncher}" VerticalAlignment="Center" Margin="0,4,8,4"/>
        <DockPanel Grid.Row="4" Grid.Column="1" Margin="0,4,0,4">
            <Button DockPanel.Dock="Right" Content="{DynamicResource S.BtnBrowse}" Width="72" Margin="4,0,0,0" Click="BrowseBtn_Click"/>
            <TextBox x:Name="_launcherPathBox" VerticalAlignment="Stretch" VerticalContentAlignment="Center"/>
        </DockPanel>

        <!-- VR -->
        <Label Grid.Row="5" Grid.Column="0" Content="{DynamicResource S.LblVr}" VerticalAlignment="Center" Margin="0,4,8,4"/>
        <CheckBox x:Name="_vrCheck" Grid.Row="5" Grid.Column="1" Content="{DynamicResource S.ChkVr}" VerticalAlignment="Center" Margin="0,4,0,4"/>

        <!-- 多重起動防止 -->
        <Label Grid.Row="6" Grid.Column="0" Content="{DynamicResource S.LblVrcCheck}" VerticalAlignment="Center" Margin="0,4,8,4"/>
        <CheckBox x:Name="_vrcCheckBox" Grid.Row="6" Grid.Column="1" Content="{DynamicResource S.ChkVrcCheck}" VerticalAlignment="Center" Margin="0,4,0,4"/>

        <!-- テーマ -->
        <Label Grid.Row="7" Grid.Column="0" Content="{DynamicResource S.LblTheme}" VerticalAlignment="Center" Margin="0,4,8,4"/>
        <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4,0,4">
            <RadioButton x:Name="_themeLightRadio"  Content="{DynamicResource S.ThemeLight}"  Margin="0,0,12,0"/>
            <RadioButton x:Name="_themeDarkRadio"   Content="{DynamicResource S.ThemeDark}"   Margin="0,0,12,0"/>
            <RadioButton x:Name="_themeSystemRadio" Content="{DynamicResource S.ThemeSystem}"/>
        </StackPanel>

        <!-- 言語 -->
        <Label Grid.Row="8" Grid.Column="0" Content="{DynamicResource S.LblLang}" VerticalAlignment="Center" Margin="0,4,8,4"/>
        <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4,0,4">
            <RadioButton x:Name="_langJaRadio" Content="日本語" Margin="0,0,12,0"/>
            <RadioButton x:Name="_langEnRadio" Content="English" Margin="0,0,12,0"/>
            <RadioButton x:Name="_langZhRadio" Content="中文" Margin="0,0,12,0"/>
            <RadioButton x:Name="_langKoRadio" Content="한국어"/>
        </StackPanel>

        <!-- ボタン -->
        <StackPanel Grid.Row="10" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="{DynamicResource S.BtnOk}"     Width="72" Height="26" Margin="0,0,4,0" Click="OkBtn_Click"/>
            <Button Content="{DynamicResource S.BtnCancel}" Width="90" Height="26" Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
