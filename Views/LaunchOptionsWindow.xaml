<Window x:Class="DekapuSkillLauncher.Views.LaunchOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.WndLaunchOptions}"
        Width="480" Height="620"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="Yu Gothic UI"
        FontSize="13"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource WindowFg}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
            <StackPanel>

                <!-- Basic -->
                <GroupBox Header="{DynamicResource S.GrpBasic}" Margin="0,0,0,8">
                    <Grid Margin="4,4,4,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="{DynamicResource S.LblVr}" VerticalAlignment="Center" Margin="0,2,8,2"/>
                        <CheckBox x:Name="_vrCheck" Grid.Row="0" Grid.Column="1" Content="{DynamicResource S.ChkVr}" VerticalAlignment="Center" Margin="0,2,0,2"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="{DynamicResource S.LblFps}" VerticalAlignment="Center" Margin="0,2,8,2"/>
                        <TextBox x:Name="_fpsBox" Grid.Row="1" Grid.Column="1" Width="80" HorizontalAlignment="Left" Margin="0,2,0,2" VerticalContentAlignment="Center"
                                 ToolTip="{DynamicResource S.TipFps}"/>
                    </Grid>
                </GroupBox>

                <!-- OSC -->
                <GroupBox Header="{DynamicResource S.GrpLaunchOsc}" Margin="0,0,0,8">
                    <Grid Margin="4,4,4,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <CheckBox x:Name="_oscCheck" Grid.Row="0" Grid.ColumnSpan="2" Content="{DynamicResource S.ChkOsc}"
                                  VerticalAlignment="Center" Margin="0,2,0,4"
                                  Checked="OscCheck_Changed" Unchecked="OscCheck_Changed"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="{DynamicResource S.LblOscInPort}" VerticalAlignment="Center" Margin="16,2,8,2"/>
                        <TextBox x:Name="_oscInPortBox" Grid.Row="1" Grid.Column="1" Width="80" HorizontalAlignment="Left" Margin="0,2,0,2" VerticalContentAlignment="Center"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="{DynamicResource S.LblOscOutIp}" VerticalAlignment="Center" Margin="16,2,8,2"/>
                        <TextBox x:Name="_oscOutIpBox" Grid.Row="2" Grid.Column="1" Margin="0,2,0,2" VerticalContentAlignment="Center"/>

                        <Label Grid.Row="3" Grid.Column="0" Content="{DynamicResource S.LblOscOutPort}" VerticalAlignment="Center" Margin="16,2,8,2"/>
                        <TextBox x:Name="_oscOutPortBox" Grid.Row="3" Grid.Column="1" Width="80" HorizontalAlignment="Left" Margin="0,2,0,2" VerticalContentAlignment="Center"/>
                    </Grid>
                </GroupBox>

                <!-- Performance -->
                <GroupBox Header="{DynamicResource S.GrpPerformance}" Margin="0,0,0,8">
                    <Grid Margin="4,4,4,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="{DynamicResource S.LblAffinity}" VerticalAlignment="Center" Margin="0,2,8,2"/>
                        <DockPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Left" Width="200" Margin="0,2,0,2">
                            <Button DockPanel.Dock="Right" Content="…" Width="28" Height="22" Margin="4,0,0,0"
                                    VerticalAlignment="Center" Click="AffinityBtn_Click"
                                    ToolTip="{DynamicResource S.TipAffinityBtn}"/>
                            <TextBox x:Name="_affinityBox" VerticalContentAlignment="Center"
                                     FontFamily="Consolas" IsReadOnly="True"/>
                        </DockPanel>

                        <Label Grid.Row="1" Grid.Column="0" Content="{DynamicResource S.LblProcessPriority}" VerticalAlignment="Center" Margin="0,2,8,2"/>
                        <ComboBox x:Name="_processPriorityCombo" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Left" Width="200" Margin="0,2,0,2"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="{DynamicResource S.LblMainThreadPriority}" VerticalAlignment="Center" Margin="0,2,8,2"/>
                        <ComboBox x:Name="_mainThreadPriorityCombo" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Left" Width="200" Margin="0,2,0,2"/>
                    </Grid>
                </GroupBox>

                <!-- Display -->
                <GroupBox Header="{DynamicResource S.GrpDisplay}" Margin="0,0,0,8">
                    <Grid Margin="4,4,4,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="{DynamicResource S.LblScreenWidth}" VerticalAlignment="Center" Margin="0,2,8,2"/>
                        <TextBox x:Name="_screenWidthBox" Grid.Row="0" Grid.Column="1" Width="80" HorizontalAlignment="Left" Margin="0,2,0,2" VerticalContentAlignment="Center"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="{DynamicResource S.LblScreenHeight}" VerticalAlignment="Center" Margin="0,2,8,2"/>
                        <TextBox x:Name="_screenHeightBox" Grid.Row="1" Grid.Column="1" Width="80" HorizontalAlignment="Left" Margin="0,2,0,2" VerticalContentAlignment="Center"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="{DynamicResource S.LblScreenFullscreen}" VerticalAlignment="Center" Margin="0,2,8,2"/>
                        <ComboBox x:Name="_screenFullscreenCombo" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Left" Width="150" Margin="0,2,0,2">
                            <ComboBoxItem Tag="-1">--</ComboBoxItem>
                            <ComboBoxItem Tag="0" Content="{DynamicResource S.FullscreenWindowed}"/>
                            <ComboBoxItem Tag="1" Content="{DynamicResource S.FullscreenFullscreen}"/>
                        </ComboBox>

                        <Label Grid.Row="3" Grid.Column="0" Content="{DynamicResource S.LblMonitor}" VerticalAlignment="Center" Margin="0,2,8,2"/>
                        <TextBox x:Name="_monitorBox" Grid.Row="3" Grid.Column="1" Width="60" HorizontalAlignment="Left" Margin="0,2,0,2" VerticalContentAlignment="Center"
                                 ToolTip="{DynamicResource S.TipMonitor}"/>

                        <Label Grid.Row="4" Grid.Column="0" Content="{DynamicResource S.LblHwVideoDecoding}" VerticalAlignment="Center" Margin="0,2,8,2"/>
                        <ComboBox x:Name="_hwVideoDecodingCombo" Grid.Row="4" Grid.Column="1" HorizontalAlignment="Left" Width="200" Margin="0,2,0,2">
                            <ComboBoxItem Tag="">--</ComboBoxItem>
                            <ComboBoxItem Tag="disable">CPU (--disable-hw-video-decoding)</ComboBoxItem>
                            <ComboBoxItem Tag="enable">GPU (--enable-hw-video-decoding)</ComboBoxItem>
                        </ComboBox>

                        <Label Grid.Row="5" Grid.Column="0" Content="{DynamicResource S.LblAmdStutter}" VerticalAlignment="Center" Margin="0,2,8,2"/>
                        <CheckBox x:Name="_disableAmdStutterCheck" Grid.Row="5" Grid.Column="1"
                                  Content="{DynamicResource S.ChkDisableAmdStutter}" VerticalAlignment="Center" Margin="0,2,0,2"/>
                    </Grid>
                </GroupBox>

                <!-- Debug -->
                <GroupBox Header="{DynamicResource S.GrpDebug}" Margin="0,0,0,8">
                    <Grid Margin="4,4,4,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <CheckBox x:Name="_watchWorldsCheck" Grid.Row="0" Grid.ColumnSpan="2" Content="{DynamicResource S.ChkWatchWorlds}" Margin="0,2,0,2"/>
                        <CheckBox x:Name="_watchAvatarsCheck" Grid.Row="1" Grid.ColumnSpan="2" Content="{DynamicResource S.ChkWatchAvatars}" Margin="0,2,0,2"/>
                        <CheckBox x:Name="_debugGuiCheck" Grid.Row="2" Grid.ColumnSpan="2" Content="{DynamicResource S.ChkDebugGui}" Margin="0,2,0,2"/>
                        <CheckBox x:Name="_sdkLogLevelsCheck" Grid.Row="3" Grid.ColumnSpan="2" Content="{DynamicResource S.ChkSdkLogLevels}" Margin="0,2,0,2"/>
                        <CheckBox x:Name="_udonDebugLoggingCheck" Grid.Row="4" Grid.ColumnSpan="2" Content="{DynamicResource S.ChkUdonDebugLogging}" Margin="0,2,0,2"/>
                        <CheckBox x:Name="_skipRegistryInstallCheck" Grid.Row="5" Grid.ColumnSpan="2" Content="{DynamicResource S.ChkSkipRegistryInstall}" Margin="0,2,0,2"/>
                        <CheckBox x:Name="_enforceWorldServerChecksCheck" Grid.Row="6" Grid.ColumnSpan="2" Content="{DynamicResource S.ChkEnforceWorldServerChecks}" Margin="0,2,0,2"/>

                        <Label Grid.Row="7" Grid.Column="0" Content="{DynamicResource S.LblIgnoreTrackers}" VerticalAlignment="Center" Margin="0,4,8,2"/>
                        <TextBox x:Name="_ignoreTrackersBox" Grid.Row="7" Grid.Column="1" Margin="0,4,0,2" VerticalContentAlignment="Center"
                                 ToolTip="{DynamicResource S.TipIgnoreTrackers}"/>

                        <Label Grid.Row="8" Grid.Column="0" Content="{DynamicResource S.LblMidi}" VerticalAlignment="Center" Margin="0,4,8,2"/>
                        <TextBox x:Name="_midiBox" Grid.Row="8" Grid.Column="1" Margin="0,4,0,2" VerticalContentAlignment="Center"/>
                    </Grid>
                </GroupBox>

                <!-- Arguments -->
                <GroupBox Header="{DynamicResource S.GrpExtraArgs}" Margin="0,0,0,4">
                    <TextBox x:Name="_extraArgsBox" Margin="4,4,4,4" VerticalContentAlignment="Center"/>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <!-- Button -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="{DynamicResource S.BtnOk}"     Width="72" Height="26" Margin="0,0,4,0" Click="OkBtn_Click"/>
            <Button Content="{DynamicResource S.BtnCancel}" Width="90" Height="26" Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
